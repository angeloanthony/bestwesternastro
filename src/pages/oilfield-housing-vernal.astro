  {
    "@context": "https://schema.org",
    "@type": "LodgingBusiness",
    "name": "Best Western Extended Stay Vernal",
    "url": "https://bestwesternvernalinn.com",
    "telephone": "+18015971696",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Vernal",
      "addressRegion": "UT",
      "addressCountry": "US"
    },
    "description": "Oilfield and energy worker housing in Vernal, Utah. Weekly and monthly hotel rates, truck parking, hot breakfast, laundry, and corporate billing for crews in the Uintah Basin.",
    "priceRange": "$$",
    "amenityFeature": [
      { "@type": "LocationFeatureSpecification", "name": "Weekly Rates", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Monthly Rates", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Truck Parking", "value": true },
      { "@type": "LocationFeatureSpecification", "name": "Free Breakfast", "value": true },
