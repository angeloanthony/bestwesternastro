      <div class="del-list">
        <div class="del-row"><span class="del-icon">🍔</span><div><strong>McDonald's</strong><span class="del-type">DoorDash &amp; Uber Eats</span></div></div>
        <div class="del-row"><span class="del-icon">🍕</span><div><strong>Domino's</strong><span class="del-type">Own app + DoorDash</span></div></div>
        <div class="del-row"><span class="del-icon">🍕</span><div><strong>Pizza Hut</strong><span class="del-type">Own app + Uber Eats</span></div></div>
