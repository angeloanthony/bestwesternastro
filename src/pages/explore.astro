      "@type": "GeoCoordinates",
      "latitude": 40.4474,
      "longitude": -109.5194
    },
    "isPartOf": {
      "@type": "Hotel",
      "name": "Best Western Extended Stay Vernal",
      "url": "https://bestwesternvernalinn.com",
      "telephone": "+14357896625",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "1935 South 1500 East",
        "addressLocality": "Vernal",
        "addressRegion": "UT",
        "postalCode": "84078",
        "addressCountry": "US"
      }
    },
    "containsPlace": [
      {
        "@type": "TouristAttraction",
        "name": "Dinosaur National Monument",
        "description": "1,500+ dinosaur bones embedded in the cliff face at the Quarry Exhibit Hall, plus canyon hikes and the Green River. ~20 minutes from Best Western Vernal.",
        "url": "https://www.nps.gov/dino/index.htm"
      },
      {
        "@type": "TouristAttraction",
        "name": "Flaming Gorge National Recreation Area",
