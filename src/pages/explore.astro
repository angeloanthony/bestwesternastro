      },
      {
        "@type": "TouristAttraction",
        "name": "McConkie Ranch Petroglyphs",
        "description": "Near-life-sized Fremont culture figures carved into canyon sandstone. ~15 minutes from Best Western Vernal.",
        "url": "https://utah.com/vernal/mcconkie-ranch-petroglyphs"
      },
      {
        "@type": "TouristAttraction",
        "name": "Red Fleet State Park",
        "description": "Dinosaur trackway hike and reservoir kayaking. ~10 minutes from Best Western Vernal.",
        "url": "https://stateparks.utah.gov/parks/red-fleet/"
      },
      {
        "@type": "TouristAttraction",
        "name": "Utah Field House of Natural History",
        "description": "Walk through 200 million years of geologic time. Life-sized dinosaur replicas, fossil prep lab. In-town attraction.",
        "url": "https://stateparks.utah.gov/parks/field-house/"
      }
    ]
  }
  </script>
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Paresh Ghandi",
    "jobTitle": "Owner / Manager",
    "description": "Local Vernal owner and guide to the Uintah Basin who transformed the former Executive Inn into Best Western Extended Stay.",
    "url": "https://bestwesternvernalinn.com/video.html",
    "worksFor": {
      "@type": "Hotel",
      "name": "Best Western Extended Stay Vernal",
      "url": "https://bestwesternvernalinn.com"
    }
  }
  </script>
<style>
    .visually-hidden {
      position: absolute !important;
      inset: -9999px !important;
      width: 1px !important;
      height: 1px !important;
      overflow: hidden !important;
      white-space: normal !important;
    }

    html, body {
      overflow-x: clip !important;
      width: 100% !important;
      max-width: 100vw !important;
    }

    @media (max-width: 900px) {
      #nav {
        padding: 0 28px 0 20px !important;
        box-sizing: border-box !important;
      }
      .burger {
        flex-shrink: 0 !important;
        margin-left: auto !important;
      }
      .ex-hero-cnt {
        padding-top: 80px !important;
      }
      .delivery-grid {
        grid-template-columns: 1fr !important;
      }
      .feature-inner {
        grid-template-columns: 1fr !important;
        gap: 36px !important;
      }
      .feature-right {
        grid-template-columns: 1fr 1fr !important;
      }
      .ex-sec {
        padding: 60px 16px !important;
      }
    }

    @media (max-width: 600px) {
      .cards-grid {
        grid-template-columns: 1fr !important;
      }
      .resto-grid {
        grid-template-columns: 1fr !important;
      }
      .delivery-btns {
        flex-direction: column !important;
      }
      .del-app-btn {
        width: 100% !important;
        justify-content: center !important;
      }
      .ex-hero-title {
        font-size: 2.2rem !important;
      }
    }
  </style>
<link rel="icon" href="images/logo.webp" type="image/webp">`;
const bodyContent = `<!-- PAGE SUMMARY — AI-extractable, invisible to users -->
<div class="visually-hidden">
  Best Western Vernal Inn | Extended stay hotel with weekly rates from $588, full kitchenettes, pet friendly ($30/day + $100 refundable deposit), free breakfast, free parking for trucks. Located at 1935 South 1500 East, Vernal, UT 84078. Phone (435) 789-6625. 20 min to Dinosaur National Monument, 40 min to Flaming Gorge. Book direct at bestwesternvernalinn.com.
</div>

<!-- NAV -->


<!-- HERO -->
<section class="ex-hero">
  <div class="ex-hero-bg">
    <iframe class="ex-hero-video"
