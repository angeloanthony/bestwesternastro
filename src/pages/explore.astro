        <div class="del-row"><span class="del-icon">🥪</span><div><strong>Arby's</strong><span class="del-type">DoorDash &amp; Uber Eats</span></div></div>
        <div class="del-row"><span class="del-icon">🍔</span><div><strong>Freddy's</strong><span class="del-type">Steakburgers &amp; Custard</span></div></div>
        <div class="del-row"><span class="del-icon">🥤</span><div><strong>Sonic Drive-In</strong><span class="del-type">DoorDash</span></div></div>
        <div class="del-row"><span class="del-icon">🧇</span><div><strong>Denny's</strong><span class="del-type">24-hr delivery option</span></div></div>
      </div>
    </div>

  </div>

  <div class="tip-box rv">
    <span class="tip-icon">📍</span>
