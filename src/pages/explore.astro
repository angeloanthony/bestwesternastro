        <div class="del-row"><span class="del-icon">🍜</span><div><strong>Khao Hom Thai Kitchen</strong><span class="del-type">Thai · Asian Fusion</span></div></div>
        <div class="del-row"><span class="del-icon">🌯</span><div><strong>Cafe Rio</strong><span class="del-type">Fast-casual Mexican</span></div></div>
