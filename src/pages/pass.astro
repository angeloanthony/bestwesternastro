---
// src/pages/pass.astro
// NEW page (AdventureOS M2 — Identity). The Vernal Adventure Pass member entry point.
// noindex utility page: it is a member surface, not an SEO page. Hosts the single
// PassDashboard island (client:only), which owns the entire member-vs-anon decision
// in the browser. No public page links here yet and none gate on it — the 23 SEO
// pages remain fully static and open (rollout gate: STAGING_CHECKLIST §D/§E).
import BaseLayout from '../layouts/BaseLayout.astro';
import PassDashboard from '../islands/PassDashboard.tsx';
import { BUSINESS } from '../data/business.ts';
---

<BaseLayout
  title="Your Vernal Adventure Pass | Best Western Vernal Inn"
  description="Create your free Vernal Adventure Pass — save the places you love, keep your trip plans in one spot, and unlock local guides. One-tap email sign-in, no password."
  canonical={`${BUSINESS.site.domain}/pass`}
  robots="noindex, follow"
>
  <section class="page-hero">
    <div class="page-hero-cnt">
      <p
        style="font-size:.85rem;letter-spacing:3px;text-transform:uppercase;margin-bottom:12px;color:var(--gold);font-weight:700;"
      >
        Vernal Adventure Pass
      </p>
      <h1
        style="font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4.5vw,3rem);font-weight:700;margin-bottom:18px;line-height:1.15;"
      >
        Your Adventure,<br />Saved &amp; Ready
      </h1>
      <p
        style="font-size:1.05rem;line-height:1.7;opacity:.88;max-width:620px;margin:0 auto;font-weight:300;"
      >
        Save favourite spots, keep your plans together, and unlock local guides for the Uintah Basin.
        Free, with a one-tap email link — no password to create.
      </p>
    </div>
  </section>

  <div class="content-wrap">
    <div
      style="max-width:760px;margin:0 auto;background:#fff;border:1px solid rgba(var(--gold-rgb),.35);border-radius:8px;padding:clamp(1.25rem,4vw,2rem);"
    >
      <PassDashboard client:only="preact" />
    </div>
    <p style="text-align:center;color:var(--muted);font-size:.9rem;margin-top:1.25rem;">
      Questions about your Pass? Call{' '}
      <a href={`tel:${BUSINESS.phoneTel}`} style="color:var(--navy);font-weight:600;"
        >{BUSINESS.phoneDisplay}</a
      >.
    </p>
  </div>
</BaseLayout>
