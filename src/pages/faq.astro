---
// src/pages/faq.astro
// MIGRATION of /faq.html — metadata, canonical, JSON-LD schema, body copy,
// headings, and internal links preserved VERBATIM. Shared chrome
// (nav / mobile menu / footer / scroll-top + burger script) is provided by
// BaseLayout; page-specific <style>/schema go in the head slot and
// page-specific scripts in the scripts slot, both emitted unchanged.
import BaseLayout from '../layouts/BaseLayout.astro';

const headExtras = `<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Paresh Ghandi",
    "jobTitle": "Owner / Manager",
    "worksFor": {
      "@type": "Hotel",
      "name": "Best Western Extended Stay Vernal",
      "url": "https://bestwesternvernalinn.com"
    }
  }
  </script>
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What are the weekly rates at Best Western Extended Stay Vernal Utah?", "acceptedAnswer": { "@type": "Answer", "text": "Weekly rates start at $588 + tax for a Standard Queen room (7 nights), $660 + tax for a Double Queen, and $700 + tax for a Standard King. Monthly rates and long-term corporate billing are available — call (435) 789-6625 for pricing." }},
      { "@type": "Question", "name": "Is the hotel pet friendly?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, Best Western Extended Stay Vernal welcomes up to two dogs per room with an 80 lb limit per dog. Pet fee is $30.00 USD per day plus a refundable $100.00 damage deposit due at check-in. Other pets may be allowed with prior approval — call (435) 789-6625." }},
      { "@type": "Question", "name": "Does Best Western Extended Stay Vernal include free breakfast?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, a free hot breakfast is included with every stay, served daily." }},
      { "@type": "Question", "name": "What time is check-in and check-out?", "acceptedAnswer": { "@type": "Answer", "text": "Check-in is at 3:00 PM. Check-out is at 11:00 AM." }},
      { "@type": "Question", "name": "Do the rooms have kitchenettes?", "acceptedAnswer": { "@type": "Answer", "text": "Most rooms at Best Western Extended Stay Vernal include a full kitchenette with a stovetop, microwave, full-size refrigerator, and coffee maker." }},
      { "@type": "Question", "name": "Is WiFi free?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, fast free WiFi is available throughout the entire hotel and in every guest room." }},
      { "@type": "Question", "name": "Is parking free?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, complimentary parking is available for all guests including trucks and work vehicles. Pull right up to your room — no fees, ever." }},
      { "@type": "Question", "name": "Do you have jacuzzi suites?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, Best Western Extended Stay Vernal offers King Jacuzzi Suites and Jacuzzi Double Queen Suites, each featuring a private in-room soaking tub." }},
      { "@type": "Question", "name": "Are ADA accessible rooms available?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, ADA accessible king rooms are available with wide doorways, roll-in showers, lowered fixtures, and ground-floor access." }},
      { "@type": "Question", "name": "Do you offer monthly rates or long-term housing for contractors and oil field workers?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, monthly rates and long-term stays are available for contractors, oil field workers, and corporate guests in the Uintah Basin. Call (435) 789-6625 for pricing." }},
      { "@type": "Question", "name": "Do you have parking for trucks and work vehicles?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, free parking is available for all vehicles including trucks and work vehicles." }},
      { "@type": "Question", "name": "How far is Best Western Extended Stay from Vernal Regional Airport?", "acceptedAnswer": { "@type": "Answer", "text": "Best Western Extended Stay Vernal is located 0.6 miles from Vernal Regional Airport (VEL) at 1935 South 1500 East, Vernal, UT 84078." }},
      { "@type": "Question", "name": "How far is the hotel from Dinosaur National Monument?", "acceptedAnswer": { "@type": "Answer", "text": "Dinosaur National Monument is approximately 20 minutes from Best Western Extended Stay Vernal." }}
    ]
  }
  </script>
<style>
    .page-summary-bar {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0,0,0,0);
      white-space: nowrap;
      border: 0;
    }
    
    .faq-a {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease-out, padding 0.3s ease, opacity 0.2s ease;
      padding: 0 22px;
      opacity: 0;
    }
    .faq-q.open + .faq-a {
      opacity: 1;
    }
  </style>
<link rel="icon" href="images/logo.webp" type="image/webp">`;
const bodyContent = `<div class="page-summary-bar" role="complementary" aria-label="Quick summary">
  <strong>FAQ — Best Western Vernal Inn.</strong> Weekly rates from $588 (7 nights). Free hot breakfast daily. Pet friendly (2 dogs, 80 lb limit, $30/day + $100 refundable deposit). Check-in 3:00 PM · Check-out 11:00 AM. Full kitchenettes, jacuzzi suites, ADA accessible rooms, free WiFi, free parking. Monthly rates and contractor housing available. Located at 1935 South 1500 East, Vernal, UT 84078. Call <strong>(435) 789-6625</strong>.
</div>



<div class="faq-hero">
  <div class="faq-hero-bg"></div>
  <p class="tag">✦ Guest Information</p>
  <h1>Frequently Asked<br><em>Questions</em></h1>
  <p>Everything you need to know before your stay at Best Western Vernal Inn.</p>
  <div class="faq-hero-divider"></div>
</div>

<section class="faq-page-sec">
  <div class="faq-categories">

    <div>
      <h2 class="faq-cat-title">💲 Rates &amp; Booking</h2>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-q">What are the weekly rates? <span class="faq-arrow">▼</span></button>
          <div class="faq-a">
            Weekly extended stay rates (7 nights + tax): <strong>Standard Queen — $588</strong>, <strong>Double Queen — $660</strong>, <strong>Standard King — $700</strong>. Monthly rates and long-term corporate billing are also available — call <a href="tel:4357896625">(435) 789-6625</a> for pricing.
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q">Do you offer monthly rates or long-term housing? <span class="faq-arrow">▼</span></button>
          <div class="faq-a">
            Yes! Monthly rates are available for long-term guests, oil field workers, contractors, and corporate travelers in the Uintah Basin. Company billing arrangements can also be discussed. Call <a href="tel:4357896625">(435) 789-6625</a> for monthly pricing and availability.
          </div>
        </div>
      </div>
    </div>

    <div>
      <h2 class="faq-cat-title">🍳 Dining</h2>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-q">Does the hotel offer breakfast? <span class="faq-arrow">▼</span></button>
          <div class="faq-a">
            Yes! A free hot breakfast is included with every stay, served daily. Start your morning with warm dishes, fresh pastries, pancakes, fruit, coffee, and more — all on us, every single day.
          </div>
        </div>
      </div>
    </div>

    <div>
      <h2 class="faq-cat-title">🐾 Pet Policy</h2>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-q">Is the hotel pet friendly? <span class="faq-arrow">▼</span></button>
          <div class="faq-a">
            Yes, we welcome up to <strong>two dogs per room</strong> with an 80 lb limit per dog. Other pet types (such as cats) may be allowed with prior hotel approval — please contact us before arrival.<br><br>
            <strong>Pet fees:</strong> $30.00 USD per day, plus a refundable $100.00 damage deposit due at check-in. If damage occurs or excessive cleaning is needed, the deposit may become non-refundable and additional charges may apply.
          </div>
        </div>
      </div>
    </div>

    <div>
      <h2 class="faq-cat-title">🕒 Check-In &amp; Check-Out</h2>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-q">What time is check-in? <span class="faq-arrow">▼</span></button>
          <div class="faq-a">
            Check-in time is <strong>3:00 PM</strong>. If you arrive early, we'll do our best to accommodate you — just give us a call at <a href="tel:4357896625">(435) 789-6625</a>.
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q">What time is check-out? <span class="faq-arrow">▼</span></button>
          <div class="faq-a">
            Check-out time is <strong>11:00 AM</strong>. Late check-out may be available upon request — contact the front desk the evening before your departure.
          </div>
        </div>
      </div>
    </div>

    <div>
      <h2 class="faq-cat-title">📶 Connectivity &amp; Parking</h2>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-q">Is Wi-Fi free? <span class="faq-arrow">▼</span></button>
          <div class="faq-a">
            Yes — fast, free Wi-Fi is available throughout the entire hotel and in every guest room. No passwords to hunt down, no fees, no limits.
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q">Is parking free? Do you have room for trucks? <span class="faq-arrow">▼</span></button>
          <div class="faq-a">
            Yes — complimentary parking is available for all guests including trucks and work vehicles. Pull right up to your room, no fees, ever.
          </div>
        </div>
      </div>
    </div>

    <div>
      <h2 class="faq-cat-title">🛏️ Rooms &amp; Suites</h2>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-q">Do the rooms have kitchenettes? <span class="faq-arrow">▼</span></button>
          <div class="faq-a">
            Most of our rooms include a full kitchenette with a stovetop, microwave, full-size refrigerator, and coffee maker — perfect for extended stays.
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q">Do you have jacuzzi suites? <span class="faq-arrow">▼</span></button>
          <div class="faq-a">
            Yes! We offer both King Jacuzzi Suites and Jacuzzi Double Queen Suites — featuring a private in-room soaking tub. Call us to check availability: <a href="tel:4357896625">(435) 789-6625</a>.
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q">Are ADA accessible rooms available? <span class="faq-arrow">▼</span></button>
          <div class="faq-a">
            Yes — we offer ADA accessible king rooms with wide doorways, roll-in showers, lowered fixtures, and ground-floor access.
          </div>
        </div>
      </div>
    </div>

    <div>
      <h2 class="faq-cat-title">📍 Location</h2>
      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-q">How far is the hotel from Vernal Regional Airport? <span class="faq-arrow">▼</span></button>
          <div class="faq-a">
            Best Western Vernal Inn is located just <strong>0.6 miles</strong> from Vernal Regional Airport (VEL) at 1935 South 1500 East, Vernal, UT 84078.
          </div>
        </div>
        <div class="faq-item">
          <button class="faq-q">How far is the hotel from Dinosaur National Monument? <span class="faq-arrow">▼</span></button>
          <div class="faq-a">
            Dinosaur National Monument is approximately <strong>20 minutes</strong> from our front door. We're an ideal base camp for exploring Dinosaur Country.
          </div>
        </div>
      </div>
    </div>

    <div class="faq-cta">
      <h3>Still Have Questions?</h3>
      <p>Our front desk team is here 24 hours a day — give us a call or send us an email and we'll be happy to help.</p>
      <p style="margin-top:8px;font-size:0.9rem;">Or explore: <a href="index.html#rooms">our rooms</a> · <a href="index.html#amenities">amenities</a> · <a href="explore.html">things to do in Vernal</a></p>
      <div class="faq-cta-btns">
        <a href="tel:4357896625" class="call">📞 (435) 789-6625</a>
        <a href="/cdn-cgi/l/email-protection#e583978a8b918180968ea5878096919280969180978b9380978b8489cb868a88" class="email">✉️ Email Us</a>
      </div>
    </div>

  </div>
</section>

