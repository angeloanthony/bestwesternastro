<BaseLayout
  title=`Dog Friendly Hotel in Vernal, Utah | Best Western Vernal Inn`
  description=`Looking for a dog friendly hotel in Vernal, Utah? Best Western Extended Stay Vernal welcomes pets. Bring your dog and explore Dinosaur National Monument, Flaming Gorge, and Utah's canyon country together. Call (435) 789-6625.`
  canonical=`https://bestwesternvernalinn.com/dog-friendly-hotel-vernal`
  ogImage=`https://bestwesternvernalinn.com/images/35.webp`
  twitterImage=`https://bestwesternvernalinn.com/images/35.webp`
  lastUpdated=`April 2026`
>
  <Fragment slot="head" set:html={headExtras} />
  <Fragment set:html={bodyContent} />
</BaseLayout>
