---
// src/pages/corporate-rates.astro
// NEW page (AdventureOS Prompt 4) — corporate rate / room-block request form.
// Utility page: noindex for now; the indexed corporate-lodging hub arrives in
// Module 7 and will link here. Hosts the CorporateRateForm island.
import BaseLayout from '../layouts/BaseLayout.astro';
import CorporateRateForm from '../islands/CorporateRateForm.tsx';
import { BUSINESS } from '../data/business.ts';
---

<BaseLayout
  title="Corporate Rates & Room Blocks | Best Western Vernal Inn"
  description="Request negotiated corporate rates or a group room block at Best Western Vernal Inn — reliable lodging for crews and companies working in the Uintah Basin."
  canonical={`${BUSINESS.site.domain}/corporate-rates`}
  robots="noindex, follow"
>
  <section class="page-hero">
    <div class="page-hero-cnt">
      <p
        style="font-size:.85rem;letter-spacing:3px;text-transform:uppercase;margin-bottom:12px;color:var(--gold);font-weight:700;"
      >
        Corporate Lodging — Uintah Basin
      </p>
      <h1
        style="font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4.5vw,3rem);font-weight:700;margin-bottom:18px;line-height:1.15;"
      >
        Corporate Rates &amp;<br />Room Blocks
      </h1>
      <p
        style="font-size:1.05rem;line-height:1.7;opacity:.88;max-width:620px;margin:0 auto;font-weight:300;"
      >
        Negotiated rates for companies and crews working the basin, and group blocks that keep your
        team together. Send the details below and our front desk will follow up — or call{' '}
        <a href={`tel:${BUSINESS.phoneTel}`} style="color:var(--gold);font-weight:700;"
          >{BUSINESS.phoneDisplay}</a
        >.
      </p>
    </div>
  </section>

  <div class="content-wrap">
    <div
      style="max-width:760px;margin:0 auto;background:#fff;border:1px solid rgba(var(--gold-rgb),.35);border-radius:8px;padding:clamp(1.25rem,4vw,2rem);"
    >
      <CorporateRateForm client:visible />
    </div>
    <p style="text-align:center;color:var(--muted);font-size:.9rem;margin-top:1.25rem;">
      Prefer email? Write us at{' '}
      <a href={`mailto:${BUSINESS.email}`} style="color:var(--navy);font-weight:600;"
        >{BUSINESS.email}</a
      >.
    </p>
  </div>
</BaseLayout>
