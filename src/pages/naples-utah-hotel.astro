    <div class="rate-cards">
      <div class="rate-card">
        <div class="rate-icon">🌙</div>
        <span class="rate-label">Nightly</span>
        <p class="rate-desc">No commitment required. Full amenities included. Best for short visits, passing through, or weekend stays.</p>
      </div>
      <div class="rate-card featured">
        <div class="rate-card-badge">Best Value</div>
        <div class="rate-icon">📅</div>
        <span class="rate-label">Weekly</span>
        <p class="rate-desc">Substantial discount over nightly rates. The go-to option for contractors, project workers, and extended family visits.</p>
      </div>
      <div class="rate-card">
        <div class="rate-icon">🏠</div>
        <span class="rate-label">Monthly</span>
        <p class="rate-desc">Our lowest per-night rate. For oilfield crews, long-term projects, and anyone on open-ended assignment in the basin.</p>
