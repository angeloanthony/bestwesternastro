# AdventureOS — environment variable template.
# Copy to `.env` (gitignored) and fill real values. NEVER commit real secrets.
# Nothing in this PR consumes these yet; they document the intended surface.

# ── Supabase (later sprint — ADR-003) ────────────────────────────
# Public (safe to expose to the browser):
PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Server-only (Workers / build scripts — NEVER expose to the client):
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ── AI Concierge Worker (later sprint — ADR-005) ─────────────────
ANTHROPIC_API_KEY="your-anthropic-key"
EMBEDDINGS_API_KEY="your-embeddings-key"

# ── Email (magic links + lead alerts) ────────────────────────────
RESEND_API_KEY="your-resend-key"
FRONT_DESK_EMAIL="frontdesk@example.com"

# ── Analytics / call tracking ────────────────────────────────────
PUBLIC_GA4_MEASUREMENT_ID="G-XXXXXXX"
PUBLIC_CALLRAIL_ID="your-callrail-swap-id"
